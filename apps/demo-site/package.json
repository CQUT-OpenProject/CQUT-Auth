{
  "name": "@cqut/demo-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:client": "node scripts/build-client.mjs",
    "dev:client": "node scripts/watch-client.mjs",
    "dev:server": "tsx watch src/main.ts",
    "build": "pnpm run build:client && tsc -p tsconfig.build.json && mkdir -p dist/public && cp -R public/. dist/public",
    "dev": "node scripts/dev.mjs",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run build:client && tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.6.0",
    "@types/supertest": "^6.0.3",
    "esbuild": "^0.27.4",
    "jsdom": "^26.1.0",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6"
  }
}
