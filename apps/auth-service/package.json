{
  "name": "@cqut/auth-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @cqut/shared build && tsc -p tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "lint": "pnpm --filter @cqut/shared build && tsc -p tsconfig.json --noEmit",
    "test": "pnpm --filter @cqut/shared build && tsx --test src/**/*.test.ts test/**/*.test.ts",
    "worker": "node dist/worker.js"
  },
  "dependencies": {
    "@cqut/shared": "workspace:*",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "axios": "^1.12.2",
    "axios-cookiejar-support": "^6.0.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "ioredis": "^5.8.1",
    "pg": "^8.16.3",
    "express": "^5.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tough-cookie": "^5.1.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.6.0",
    "@types/pg": "^8.15.5",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6"
  }
}
