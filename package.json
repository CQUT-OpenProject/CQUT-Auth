{
  "name": "cqut-auth",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r build",
    "check:env-source": "bash ../scripts/check-single-env-source.sh",
    "dev": "pnpm --filter @cqut/oidc-op dev",
    "dev:oidc": "pnpm --filter @cqut/oidc-op dev",
    "init-env": "node scripts/init-env.mjs",
    "init-env:stdout": "node scripts/init-env.mjs --stdout",
    "lint": "pnpm run check:env-source && pnpm -r lint",
    "test": "pnpm -r test",
    "format": "prettier --write ."
  },
  "pnpm": {
    "overrides": {
      "lodash": "^4.18.0",
      "path-to-regexp": "^8.4.0"
    }
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "typescript": "^6.0.2"
  }
}
