# ==============================
# 运行环境与基础服务
# ==============================
# 应用运行环境：production | local | test
APP_ENV=production
# 认证提供方类型：当前支持 cqut
AUTH_PROVIDER=cqut
# OIDC 对外发行者地址（需与实际访问域名/协议/端口一致）
OIDC_ISSUER=https://auth-cqut.xxx.com:8443

# ==============================
# 数据存储（Redis / PostgreSQL）
# ==============================
# Redis 连接串（用于会话、速率限制等缓存能力）
REDIS_URL=redis://redis:6379
# PostgreSQL 用户名
POSTGRES_USER=postgres
# PostgreSQL 密码（请仅在 deploy/.env 中填写真实值）
POSTGRES_PASSWORD=<set-in-deploy-env>
# PostgreSQL 数据库名
POSTGRES_DB=cqut_auth

# ==============================
# 反向代理与网络入口（Nginx）
# ==============================
# Nginx 容器映射到宿主机的 HTTP 端口（可选调整）
OIDC_HTTP_PORT=80
# Nginx 容器映射到宿主机的 HTTPS 端口（可选调整）
OIDC_HTTPS_PORT=8443
# 信任的反向代理跳数（按实际代理层级配置）
TRUST_PROXY_HOPS=1
# 站点服务域名（用于 Nginx server_name）
SERVER_NAME=verify.local

# ==============================
# TLS 证书路径（容器内路径）
# ==============================
# TLS 证书链文件路径
TLS_CERT_PATH=/etc/nginx/certs/fullchain.pem
# TLS 私钥文件路径
TLS_KEY_PATH=/etc/nginx/certs/privkey.pem

# ==============================
# OIDC 安全密钥与 Cookie 安全
# ==============================
# 是否仅通过 HTTPS 发送 Cookie（生产环境应保持 true）
OIDC_COOKIE_SECURE=true
# OIDC 密钥加密主密钥（必须在 deploy/.env 中设置高强度随机值）
OIDC_KEY_ENCRYPTION_SECRET=<set-in-deploy-env>
# OIDC Artifact 加密密钥（必须在 deploy/.env 中设置高强度随机值）
OIDC_ARTIFACT_ENCRYPTION_SECRET=<set-in-deploy-env>
# Cookie 签名密钥组（生产必填，至少两个；且每个值都需不同于 OIDC_KEY_ENCRYPTION_SECRET 与 OIDC_CSRF_SIGNING_SECRET）
OIDC_COOKIE_KEYS=<set-in-deploy-env>,<set-in-deploy-env>
# CSRF 签名密钥（生产必填，且需不同于 OIDC_KEY_ENCRYPTION_SECRET）
OIDC_CSRF_SIGNING_SECRET=<set-in-deploy-env>

# ==============================
# 会话、交互与令牌时效（单位：秒）
# ==============================
# CSRF Token 有效期
OIDC_CSRF_TOKEN_TTL_SECONDS=600
# 用户会话总有效期
OIDC_SESSION_TTL_SECONDS=28800
# 会话空闲超时时间
OIDC_SESSION_IDLE_TTL_SECONDS=7200
# OIDC 交互会话有效期（如登录/授权交互）
OIDC_INTERACTION_TTL_SECONDS=900
# Refresh Token 有效期
OIDC_REFRESH_TTL_SECONDS=2592000

# ==============================
# 邮箱验证码（Resend）
# ==============================
# 是否启用邮箱验证码（默认 true）
OIDC_EMAIL_VERIFICATION_ENABLED=true
# Resend API Key（仅在 deploy/.env 中填写真实值）
RESEND_API_KEY=<set-in-deploy-env>
# 发件地址（必须是 Resend 已验证域名下地址）
OIDC_EMAIL_FROM=CQUT Auth <no-reply@auth-cqut.ciallichannel.com>
# 验证码有效期（秒）
OIDC_EMAIL_VERIFY_CODE_TTL_SECONDS=600
# 重新发送冷却时间（秒）
OIDC_EMAIL_VERIFY_RESEND_COOLDOWN_SECONDS=60
# 单次验证码最大尝试次数
OIDC_EMAIL_VERIFY_MAX_ATTEMPTS=5

# ==============================
# 限流策略（内存限流器）
# ==============================
# 限流异常时是否“失败即拒绝”（true 更安全，false 可用性更高）
OIDC_RATE_LIMIT_FAIL_CLOSED=true
# 内存限流器允许保留的最大 key 数量
OIDC_RATE_LIMIT_MEMORY_MAX_KEYS=10000
# 内存限流器清理过期 key 的周期
OIDC_RATE_LIMIT_MEMORY_CLEANUP_INTERVAL_SECONDS=60

# ==============================
# Artifact 清理任务
# ==============================
# 是否启用定时清理任务
OIDC_ARTIFACT_CLEANUP_ENABLED=true
# 定时清理 Cron 表达式
OIDC_ARTIFACT_CLEANUP_CRON="*/5 * * * *"
# 是否启用机会式清理（在请求链路中按采样触发）
OIDC_ARTIFACT_OPPORTUNISTIC_CLEANUP_ENABLED=false
# 机会式清理采样率（0~1）
OIDC_ARTIFACT_OPPORTUNISTIC_CLEANUP_SAMPLE_RATE=0.01
# 单次机会式清理批次大小
OIDC_ARTIFACT_OPPORTUNISTIC_CLEANUP_BATCH_SIZE=200
# 机会式清理最小触发间隔（秒）
OIDC_ARTIFACT_OPPORTUNISTIC_CLEANUP_INTERVAL_SECONDS=30

# ==============================
# OIDC 客户端配置（JSON 文件）
# ==============================
# 客户端配置文件路径（容器内路径）；业务站客户端统一从 JSON 批量导入
OIDC_CLIENTS_CONFIG_PATH=/app/config/oidc-clients.json

# ==============================
# 上游认证源（CQUT）与请求超时
# ==============================
# 单次上游请求超时时间（毫秒）
PROVIDER_TIMEOUT_MS=10000
# 整体认证流程总超时（毫秒）
PROVIDER_TOTAL_TIMEOUT_MS=20000
# CQUT UIS 基础地址
CQUT_UIS_BASE_URL=https://uis.cqut.edu.cn
# CQUT CAS 应用编码
CQUT_CAS_APPLICATION_CODE=officeHallApplicationCode
# CQUT CAS 服务地址（通常包含 applicationCode 参数）
CQUT_CAS_SERVICE_URL=https://uis.cqut.edu.cn/ump/common/login/authSourceAuth/auth?applicationCode=officeHallApplicationCode
